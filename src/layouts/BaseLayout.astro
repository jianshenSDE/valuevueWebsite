---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
}

const {
  title,
  description = 'ValueVue LLC — Commercial real estate appraisal and advisory services in Texas. MAI-designated appraiser delivering reliable property valuations.',
  ogTitle,
  ogDescription,
  ogImage = '/og-image.jpg',
} = Astro.props;

const siteTitle = title === 'Home' ? 'ValueVue LLC — Commercial Real Estate Appraisal & Advisory' : `${title} | ValueVue LLC`;
const siteUrl = 'https://www.valuevuellc.com';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  'name': 'ValueVue LLC',
  'description': 'Commercial real estate appraisal and advisory services in Texas. MAI-designated appraiser delivering reliable property valuations.',
  'url': siteUrl,
  'logo': `${siteUrl}/vv-logo.png`,
  'image': `${siteUrl}/og-image.jpg`,
  'email': 'info@valuevuellc.com',
  'address': {
    '@type': 'PostalAddress',
    'addressRegion': 'TX',
    'addressCountry': 'US',
  },
  'areaServed': {
    '@type': 'State',
    'name': 'Texas',
  },
  'founder': {
    '@type': 'Person',
    'name': 'Zoe Ying Zhang',
    'jobTitle': 'Chief Appraiser & Founder',
  },
  'knowsAbout': [
    'Commercial Real Estate Appraisal',
    'Appraisal Review Services',
    'Litigation Support',
    'Expert Witness Testimony',
    'Portfolio Valuations',
    'Consulting & Advisory',
  ],
  'priceRange': '$$',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="ValueVue LLC" />
    <meta name="geo.region" content="US-TX" />
    <meta name="geo.placename" content="Texas" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="ValueVue LLC" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle || siteTitle} />
    <meta property="og:description" content={ogDescription || description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.url.href} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle || siteTitle} />
    <meta name="twitter:description" content={ogDescription || description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{siteTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
