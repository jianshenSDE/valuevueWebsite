---
export interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description } = Astro.props;
---

<div class="group bg-white border border-brand-100 rounded-xl p-8 hover:shadow-lg hover:border-brand-200 transition-all duration-300">
  <div class="w-12 h-12 bg-brand-50 rounded-lg flex items-center justify-center mb-5 group-hover:bg-brand-100 transition-colors">
    <svg class="w-6 h-6 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
    </svg>
  </div>
  <h3 class="text-lg font-heading font-semibold text-brand-900 mb-3">{title}</h3>
  <p class="text-sm text-brand-600 leading-relaxed">{description}</p>
</div>
