---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-900 text-brand-200">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Company Info -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-brand-700 rounded-lg flex items-center justify-center">
            <span class="text-white font-heading font-bold text-lg">VV</span>
          </div>
          <div class="leading-tight">
            <span class="block text-lg font-heading font-bold text-white">ValueVue</span>
            <span class="block text-xs text-brand-400 tracking-wider uppercase">LLC</span>
          </div>
        </div>
        <p class="text-sm text-brand-300 leading-relaxed">
          Commercial real estate appraisal and advisory services based in Texas. Delivering reliable valuations backed by deep market expertise.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-brand-300 hover:text-white transition-colors">Home</a></li>
          <li><a href="/services" class="text-sm text-brand-300 hover:text-white transition-colors">Services</a></li>
          <li><a href="/about" class="text-sm text-brand-300 hover:text-white transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm text-brand-300 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contact</h4>
        <ul class="space-y-2 text-sm text-brand-300">
          <li>Texas, United States</li>
          <li>
            <a href="mailto:info@valuevuellc.com" class="hover:text-white transition-colors">info@valuevuellc.com</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-brand-700 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-brand-400">&copy; {currentYear} ValueVue LLC. All rights reserved.</p>
    </div>
  </div>
</footer>
