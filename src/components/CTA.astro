---
export interface Props {
  title: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  title,
  description,
  buttonText = 'Contact Us',
  buttonHref = '/contact',
} = Astro.props;
---

<section class="bg-brand-800">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 md:py-20 text-center">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4" set:html={title.replace(/&/g, '<span class="font-sans">&amp;</span>')} />
    {description && (
      <p class="text-brand-200 text-lg max-w-2xl mx-auto mb-8">{description}</p>
    )}
    <a
      href={buttonHref}
      class="inline-flex items-center px-8 py-3.5 bg-white text-brand-800 font-semibold rounded-md hover:bg-brand-50 transition-colors shadow-lg"
    >
      {buttonText}
      <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>
