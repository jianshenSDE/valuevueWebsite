---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTA from '../components/CTA.astro';

const services = [
  {
    title: 'Commercial Real Estate Appraisals',
    description: 'Comprehensive appraisal services for retail, industrial, office, multifamily, hospitality, land, and other commercial property types throughout Austin, Waco, and Central Texas.',
  },
  {
    title: 'Appraisal Review Services',
    description: 'Thorough third-party review of appraisal reports to ensure quality, accuracy, and compliance with applicable standards and regulations.',
  },
  {
    title: 'Litigation Support & Expert Witness',
    description: 'Expert testimony and valuation analysis for disputes, litigation support, and tax appeals.',
  },
  {
    title: 'Portfolio Valuations',
    description: 'Multi-property portfolio appraisals for institutional lenders, investors, and corporate clients.',
  },
  {
    title: 'Consulting & Advisory',
    description: 'Market studies, feasibility analysis, highest and best use studies, and strategic real estate advisory services.',
  },
];

const trustPoints = [
  { label: 'MAI Designated', detail: 'Member of the Appraisal Institute' },
  { label: 'Texas Certified', detail: 'State Certified General Real Estate Appraiser' },
  { label: 'Decade of Experience', detail: 'Over a decade of commercial appraisal expertise' },
  { label: 'Diverse Property Types', detail: 'Retail, industrial, office, hospitality, land, and more' },
];
---

<BaseLayout
  title="Home"
  ogTitle="Commercial Appraiser Austin TX | MAI Appraiser — ValueVue LLC"
  ogDescription="MAI-designated commercial real estate appraiser serving Austin, Waco & Central Texas. Trusted property valuations by Zoe Ying Zhang with over a decade of experience."
>
  <!-- Hero -->
  <Hero
    variant="home"
    subtitle="MAI-Designated Commercial Real Estate Appraiser"
    title="Austin's Trusted Commercial Appraiser"
    description="ValueVue LLC delivers reliable commercial real estate appraisals and advisory services across Austin, Waco, and Central Texas. Led by an MAI-designated appraiser with over a decade of industry expertise."
    ctaText="Schedule a Consultation"
    ctaHref="/contact"
  />

  <!-- Services Overview -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeading
        subtitle="Our Services"
        title="Commercial Appraisal & Advisory Services in Central Texas"
        description="We provide a full range of commercial real estate appraisal and consulting services to support lenders, attorneys, investors, and property owners across Austin, Waco, and the surrounding region."
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <ServiceCard title={service.title} description={service.description} />
        ))}
      </div>
      <div class="text-center mt-12">
        <a
          href="/services"
          class="inline-flex items-center text-brand-700 font-semibold hover:text-brand-900 transition-colors"
        >
          View All Services
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Trust / Credibility Section -->
  <section class="py-20 md:py-28 bg-brand-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeading
        subtitle="Why ValueVue"
        title="Credentials You Can Count On"
        description="Our MAI-designated principal appraiser brings recognized credentials, deep Central Texas market knowledge, and a commitment to analytical rigor."
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {trustPoints.map((point) => (
          <div class="text-center">
            <div class="w-14 h-14 bg-brand-800 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-brand-900 text-lg mb-2">{point.label}</h3>
            <p class="text-sm text-brand-600">{point.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Intro -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-brand-500 text-sm font-semibold uppercase tracking-widest mb-2">About Us</p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-900 mb-6">
            MAI Appraiser Serving Austin, Waco & Central Texas
          </h2>
          <p class="text-brand-600 leading-relaxed mb-4">
            ValueVue LLC is a commercial real estate appraisal firm based in Austin, Texas, founded by Zoe Ying Zhang, MAI. With over a decade of experience as a commercial appraiser in Austin and throughout Central Texas, Ms. Zhang has appraised a wide range of property types including retail complexes, industrial facilities, office buildings, multi-family developments, hotels, farm and ranch land, and special-use properties.
          </p>
          <a
            href="/about"
            class="inline-flex items-center text-brand-700 font-semibold hover:text-brand-900 transition-colors"
          >
            Learn More About Us
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <!-- TODO: Add professional photo or firm image here -->
        <!-- <div class="bg-brand-50 rounded-2xl p-12 flex items-center justify-center min-h-[320px]">
          <img src="/photo.jpg" alt="ValueVue office" class="rounded-xl object-cover w-full h-full" />
        </div> -->
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-20 md:py-28 bg-brand-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeading
        subtitle="Service Area"
        title="Serving Austin, Waco & All of Central Texas"
        description="We provide commercial appraisal services throughout Central Texas, including the following communities."
      />
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {[
          'Austin',
          'Waco',
          'Georgetown',
          'Cedar Park',
          'Leander',
          'Pflugerville',
          'Killeen',
          'Temple',
          'Manor',
          'Elgin',
          'Lampasas',
          'Central Texas',
        ].map((city) => (
          <div class="bg-white rounded-lg px-5 py-4 text-center shadow-sm">
            <span class="text-sm font-medium text-brand-700">{city}</span>
          </div>
        ))}
      </div>
      <p class="text-center text-sm text-brand-500 mt-6">Don't see your area? <a href="/contact" class="text-brand-700 font-semibold hover:text-brand-900 transition-colors">Contact us</a> — we likely serve your location.</p>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    title="Ready to Discuss Your Appraisal Needs?"
    description="Contact us today for a commercial real estate appraisal in Austin, Waco, or anywhere in Central Texas."
    buttonText="Get in Touch"
  />
</BaseLayout>
